{
  "name": "iconify-json-nucleo",
  "version": "0.0.0",
  "private": true,
  "description": "Nucleo icon sets as license-gated Iconify icon sets",
  "license": "MIT",
  "type": "module",
  "workspaces": [
    "packages/codegen"
  ],
  "scripts": {
    "build": "bun run build:codegen",
    "build:codegen": "bun run --filter 'iconify-json-nucleo-codegen' build",
    "sync": "bun run scripts/sync-families.ts && prettier --write --log-level warn packages/families",
    "sync:check": "bun run sync && git diff --exit-code -- packages/families",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@commitlint/types": "^21.0.1",
    "@eslint/js": "^10.0.1",
    "@types/bun": "^1.3.14",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "^10.5.0",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jiti": "^2.7.0",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.4",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs,cjs}": "eslint --fix",
    "*": "prettier --ignore-unknown --write"
  },
  "engines": {
    "bun": ">=1.2.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JonathanXDR/iconify-json-nucleo.git"
  },
  "homepage": "https://github.com/JonathanXDR/iconify-json-nucleo#readme",
  "bugs": {
    "url": "https://github.com/JonathanXDR/iconify-json-nucleo/issues"
  },
  "author": "Jonathan Russ",
  "keywords": [
    "iconify",
    "icons",
    "svg",
    "nucleo"
  ]
}
