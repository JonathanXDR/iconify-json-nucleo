  "homepage": "https://github.com/JonathanXDR/iconify-json-nucleo/tree/main/packages/families/social-media#readme",
  "bugs": {
    "url": "https://github.com/JonathanXDR/iconify-json-nucleo/issues"
  },
  "author": "Jonathan Russ",
